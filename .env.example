# SINT Gateway Server — Environment Variables

# Server
SINT_PORT=3100

# Storage backend: "memory" (default) or "postgres"
SINT_STORE=memory

# Cache backend: "memory" (default) or "redis"
SINT_CACHE=memory

# PostgreSQL (required when SINT_STORE=postgres)
# DATABASE_URL=postgresql://sint:sint@localhost:5432/sint

# Redis (required when SINT_CACHE=redis)
# REDIS_URL=redis://localhost:6379

# Authentication
# SINT_API_KEY=your-admin-api-key-here
# SINT_REQUIRE_SIGNATURES=false

# Rate limiting
SINT_RATE_LIMIT=100
